#!/bin/bash

set -eo pipefail

CC=(@CC@)
CXX=(@CXX@)
GCC=(@GCC@)
GXX=(@GXX@)
PREFIX=@PREFIX@
PLUGIN=@PLUGIN@
SCRIPT=@SCRIPT@

if [[ -t 2 ]] || [[ -n "${CLICOLOR_FORCE}" ]]; then
    declare -r ANSI_BLUE='\33[34;1m'
    declare -r ANSI_RESET='\33[0m'
else
    declare -r ANSI_BLUE=''
    declare -r ANSI_RESET=''
fi

printq() {
    printf '%q' "$1"
    shift
    [[ $# -eq 0 ]] || printf ' %q' "$@"
    printf '\n'
}

usage() {
    cat 1>&2 <<-EOF
usage: ffi-cdecl [-c compiler] [-d dependency] [-o output.lua] [-n] [-D…|-I…|-U…]* input.c

    -c compiler    Select compiler: c or c++ (otherwise determined by the input extension)
    -d dependency  Add additional cflags from specified pkg-config dependency
    -o output      Set output file (instead of stdout)
    -f flags       Extra flags forwarded to the compiler

    -D/-I/-U       Those flags are forwarded to the compiler

    -n             Dry-run, show final compiler command only
EOF
    exit 1
}

[[ $# -gt 0 ]] || usage

pkg-config() {
    env \
        PKG_CONFIG_PATH="${PREFIX}/lib/pkgconfig" \
        pkg-config --env-only --cflags "$@"
}

compiler=''
dry_run=''
output='-'
verbose=0

cflags=(
    -I"${PREFIX}/include/ffi-cdecl"
    -I"${PREFIX}/include"
)

while getopts 'c:d:f:o:D:I:U:h:nv' opt; do
    case "${opt}" in
        c)
            case "${OPTARG}" in
                c | c++)
                    compiler="${OPTARG}"
                    ;;
                *)
                    usage
                    ;;
            esac
            ;;
        d)
            read -ra a < <(pkg-config --cflags "${OPTARG}")
            cflags+=("${a[@]}")
            ;;
        f)
            declare -a "a=(${OPTARG})"
            cflags+=("${a[@]}")
            ;;
        n)
            dry_run=1
            ;;
        o)
            output="${OPTARG}"
            ;;
        v)
            verbose=$((verbose + 1))
            ;;
        [DIU])
            cflags+=("-${opt}${OPTARG}")
            ;;
        [h?])
            usage
            ;;
    esac
done

shift $((OPTIND - 1))

[[ $# -eq 1 ]] || usage

if [[ -z "${compiler}" ]]; then
    case "$1" in
        *.C | *.cc | *.cpp | *.CPP | *.c++ | *.cp | *.cxx)
            compiler='c++'
            ;;
        *)
            compiler='c'
            ;;
    esac
fi

case "${compiler}" in
    c)
        native_cmd=("${CC[@]}")
        plugin_cmd=("${GCC[@]}")
        ;;
    c++)
        native_cmd=("${CXX[@]}")
        plugin_cmd=("${GXX[@]}")
        ;;
esac

native_cmd+=("${cflags[@]}" -E -P "$1")

plugin_cmd+=(
    -fplugin="${PLUGIN}"
    -fplugin-arg-gcclua-script="${SCRIPT}"
    -fplugin-arg-gcclua-output=-
    -S
    -o /dev/null
    -x "${compiler}"
    -
)

# shellcheck disable=2034
pre_fixups_cmd=(
    sed
    # Clang.
    -e '/^typedef __float128 _Float128;$/d'
    -e '/^typedef float _Float32;$/d'
    -e '/^typedef double _Float64;$/d'
    -e '/^typedef double _Float32x;$/d'
    -e '/^typedef long double _Float64x;$/d'
    # Android.
    -e 's/\<__availability__(android[^)]*)//'
    -e '/^int ioctl(int __fd, unsigned __request, \.\.\.) __attribute__((overloadable))/d'
)

# shellcheck disable=2034
post_fixups_cmd=(
    sed
    -e 's/ __attribute__((visibility("default")));$/;/'
)

pipe=''
result=''
for cmd in native_cmd pre_fixups_cmd plugin_cmd post_fixups_cmd; do
    eval "set -- \"\${${cmd}[@]}\""
    if [[ -n "${dry_run}" ]] || [[ ${verbose} -gt 0 ]]; then
        printf '%b' "${ANSI_BLUE}"
        printf '%s ' ▹ ${pipe:+|}
        printq "$@" 1>&2
        printf '%b' "${ANSI_RESET}"
    fi
    if [[ -z "${dry_run}" ]]; then
        result="$("$@" <<<"${result}")"
        if [[ ${verbose} -gt 1 ]]; then
            printf '%s\n' "${result}" 1>&2
        fi
    fi
    pipe=1
done

if [[ -n "${dry_run}" ]]; then
    exit
fi

if [[ "${output}" != '-' ]]; then
    exec >"${output}"
fi

printf -- '-- Automatically generated with ffi-cdecl.\n\n'
printf '%s\n' "${result}"

# vim: sw=4
